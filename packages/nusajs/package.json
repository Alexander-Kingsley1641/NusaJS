{
  "name": "nusajs",
  "version": "0.0.1",
  "description": "NusaJS core CLI and compiler (Pre-Alpha).",
  "author": "Alex",
  "license": "MIT",
  "type": "module",
  "bin": {
    "nusajs": "./bin/nusajs.js"
  },
